# =========================================================================
# Order Management System - Environment Configuration Example
# =========================================================================
# Copy this file to '.env' and fill in your actual credentials.
# This file is used for local development and as a reference for cloud deployment.

# --- Server Configuration ---
# The port the Spring Boot application will listen on.
# Default: 9090
PORT=9090

# --- Database Configuration (MySQL) ---
# SPRING_DATASOURCE_URL: The JDBC connection string for your MySQL database.
# IMPORTANT: For Java/Spring Boot, it MUST start with 'jdbc:mysql://'
# Local Example: jdbc:mysql://localhost:3306/order_db
# Railway Example: jdbc:mysql://crossover.proxy.rlwy.net:12345/railway
SPRING_DATASOURCE_URL=jdbc:mysql://your_db_host:port/database_name

# Database credentials
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_secure_password

# --- Cloudinary Configuration (Image Uploads) ---
# Get these from your Cloudinary Dashboard: https://cloudinary.com/console/
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Security Configuration ---
# (Optional) JWT Secret can be externalized here if you update JwtService.java
# JWT_SECRET=32704578482F4D6251655468576D5A7133743677397A24432646294A404D6351

# =========================================================================
# Deployment Tips:
# 1. On Railway: Add these variables in the 'Variables' tab of your service.
# 2. Local: Use 'dotenv' or set these in your shell before running './mvnw spring-boot:run'.
# 3. Docker: Pass these via -e or an --env-file.
# =========================================================================
